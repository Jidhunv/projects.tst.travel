# =============================================================================
# CRM PLATFORM ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update values for your deployment
# DO NOT commit .env file to version control (it may contain secrets)
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection
DATABASE_URL=postgresql://crm_user:your_password@localhost:5432/crm_db

# Database Details (for TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=your_secure_password_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Environment: development | staging | production
NODE_ENV=production

# Server Port
PORT=3001

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT Secret (min 32 characters, must be random/strong)
JWT_SECRET=your_very_long_random_jwt_secret_key_min_32_chars

# JWT Token Expiration (in seconds)
JWT_EXPIRATION=3600

# =============================================================================
# EMAIL / SMTP CONFIGURATION
# =============================================================================

# Gmail SMTP Example:
# - Enable 2-factor authentication on Gmail
# - Create an App Password: https://myaccount.google.com/apppasswords
# - Use the 16-character app password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Alternative SMTP Providers:
# Office 365: smtp.office365.com:587
# SendGrid: smtp.sendgrid.net:587
# AWS SES: email-smtp.[region].amazonaws.com:587
# Custom: your-smtp-server.com:25

# Email Sending Configuration
SMTP_FROM_EMAIL=noreply@tst.travel
SMTP_FROM_NAME=CRM System

# Enable/Disable Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend URL (for email links, CORS, etc.)
FRONTEND_URL=http://localhost:3000

# API Base URL (used by frontend)
VITE_API_URL=http://localhost:3001

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log Level: error | warn | info | debug | trace
LOG_LEVEL=info

# Enable detailed logging
DEBUG=false

# =============================================================================
# DOCKER & DEPLOYMENT
# =============================================================================

# Docker Environment
DOCKER_BUILDKIT=1

# Compose Project Name
COMPOSE_PROJECT_NAME=crm

# =============================================================================
# THIRD-PARTY SERVICES (Optional)
# =============================================================================

# Sentry Error Tracking (optional)
SENTRY_DSN=

# NewRelic Monitoring (optional)
NEW_RELIC_LICENSE_KEY=

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Force HTTPS
FORCE_HTTPS=false

# Session Secret (min 32 characters)
SESSION_SECRET=your_session_secret_min_32_chars

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================

# Before deploying to production:
# 1. Generate strong JWT_SECRET: openssl rand -base64 32
# 2. Generate strong SESSION_SECRET: openssl rand -base64 32
# 3. Update SMTP credentials with real provider
# 4. Update FRONTEND_URL and VITE_API_URL to production domains
# 5. Set NODE_ENV=production
# 6. Set FORCE_HTTPS=true
# 7. Use strong database password
# 8. Enable monitoring/logging services
# 9. Setup SSL certificates
# 10. Test all features in staging first

# Example Production Values:
# NODE_ENV=production
# FRONTEND_URL=https://crm.example.com
# VITE_API_URL=https://api.example.com
# FORCE_HTTPS=true
# LOG_LEVEL=warn
