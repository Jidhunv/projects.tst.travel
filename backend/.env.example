# ============================================
# SECURITY: CRM Application Configuration
# ============================================
# ⚠️  IMPORTANT: This file should NOT be committed to version control
# Use .env.local for local development (not tracked)
# In production, use environment variables from a secrets manager
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL must be running locally on port 5432
# Create database and user with:
# createdb -U postgres crm_db
# psql -U postgres -c "CREATE USER crm_user WITH PASSWORD 'strong_password';"

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=crm_db
DB_SSL=false

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# JWT & SECURITY
# ============================================
# GENERATE A NEW JWT_SECRET using:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# GENERATE A NEW SESSION_SECRET using:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# DO NOT use the examples below in production!
JWT_SECRET=0jKOcrSNPLk/jyv3nprjoU+nj81gGNCY8auNXsoENac=
JWT_EXPIRATION=3600
SESSION_SECRET=HvlLWaPiNIojnbDzD2Tw00U4nzco4mCMEvQIsieyO7U=
FORCE_HTTPS=false

# ============================================
# CORS & FRONTEND
# ============================================
CORS_ORIGIN=http://localhost:3000

# ============================================
# OPTIONAL: EMAIL & NOTIFICATIONS
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@tst.travel

# ============================================
# OPTIONAL: REDIS (for token blacklist, rate limiting)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY NOTES
# ============================================
# 1. Generate a strong JWT_SECRET (64 hex characters minimum)
# 2. Use FORCE_HTTPS=true in non-production environments
# 3. Set NODE_ENV=production in production
# 4. Update DB_PASSWORD to a strong, random password
# 5. Use .env.local for local development (never commit actual secrets)
# 6. In production, inject environment variables from secrets manager
# 7. Minimum password requirement: 8 characters + uppercase + lowercase + number + special char
# 8. All auth cookies are HTTPOnly and Secure (HTTPS enforced)
# 9. CSRF protection is enabled on all unsafe HTTP methods
# 10. Rate limiting: 5 login attempts per 15 minutes
