<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #1976d2; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
    .content { background: #f9f9f9; padding: 20px; border: 1px solid #ddd; border-radius: 0 0 5px 5px; }
    .opp-info { background: white; border-left: 4px solid #4caf50; padding: 15px; margin: 15px 0; }
    .opp-info p { margin: 8px 0; }
    .stage-change { background: #e8f5e9; border-left: 4px solid #4caf50; padding: 15px; margin: 15px 0; }
    .button { display: inline-block; background: #1976d2; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }
    .footer { margin-top: 20px; padding-top: 20px; border-top: 1px solid #ddd; font-size: 12px; color: #666; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📊 Opportunity Updated</h1>
    </div>
    <div class="content">
      <p>Hi {{userName}},</p>

      <p>An opportunity you're tracking has been updated:</p>

      <div class="opp-info">
        <p><strong>Opportunity:</strong> {{opportunityName}}</p>
        <p><strong>Account:</strong> {{accountName}}</p>
        <p><strong>Amount:</strong> ${{amount}}</p>
      </div>

      <div class="stage-change">
        <p><strong>Stage Changed:</strong></p>
        <p>{{oldStage}} → <strong>{{newStage}}</strong></p>
      </div>

      <a href="{{dashboardLink}}" class="button">View Opportunity</a>

      <div class="footer">
        <p>© {{year}} CRM System. All rights reserved.</p>
      </div>
    </div>
  </div>
</body>
</html>
